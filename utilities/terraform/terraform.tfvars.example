# Copy to terraform.tfvars and edit before running `terraform apply`.
# Anything left commented out will fall back to the default in variables.tf.

resource_group_name = "rg-discovery-terraform"
location            = "swedencentral"

# Optional: pin a fixed suffix so resource names are stable across runs.
# name_suffix = "dev01"

# Optional: override any auto-generated name.
# supercomputer_name         = "sc-discovery-dev"
# workspace_name             = "ws-discovery-dev"
# storage_container_name     = "stc-discovery-dev"
# project_name               = "prj-discovery-dev"
# vnet_name                  = "vnet-discovery-dev"
# managed_identity_name      = "uami-discovery-dev"
# storage_account_name       = "stgdiscoverydev01"   # must be globally unique, 3-24 lowercase alphanumeric

# Node pool sizing (defaults are fine for a smoke test).
# node_pool_vm_size            = "Standard_D4s_v6"
# node_pool_min_node_count     = 0
# node_pool_max_node_count     = 3
# node_pool_scale_set_priority = "Regular"

# Chat model (verify format + name are available in your region via the Discovery model catalog).
# chat_model_deployment_name = "gpt-5-2"
# chat_model_format          = "OpenAI"
# chat_model_name            = "gpt-5.2"
